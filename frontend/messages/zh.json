  "Life": {
    "guideTitle": "留学生活指南",
    "guideIntro": "踏上留学之旅，不仅是学术的深造，更是人生的历练。了解目标国家的生活方方面面，让你的留学生活更加顺利和丰富。我们整理了详细的生活指南，帮助你快速融入海外生活。",
    "housing": {
      "title": "住宿安排",
      "desc": "在德国，留学生可以选择学生宿舍（Studentenwohnheim）、合租公寓（WG）或单独租房。学生宿舍价格最低，约250-400欧元/月，但名额有限需提前申请。合租公寓是最受欢迎的选择，月租约350-600欧元。我们会协助学生在出发前安排好住宿。"
    },
    "transport": {
      "title": "交通出行",
      "desc": "德国公共交通系统发达，留学生可购买学期票（Semesterticket），覆盖所在城市及周边地区的公交、地铁和区域火车。此外，德铁（DB）提供多种优惠票价，BahnCard 25/50可享受相应折扣。骑自行车也是德国学生的主要出行方式。"
    },
    "food": {
      "title": "饮食文化",
      "desc": "德国大学食堂（Mensa）提供经济实惠的餐食，一顿饭约2-5欧元。超市如Aldi、Lidl、REWE等选择丰富，自己做饭每月食品支出约200-300欧元。亚洲超市也越来越多，可以买到中国食材。德国啤酒和面包种类繁多，值得尝试。"
    },
    "culture": {
      "title": "文化适应",
      "desc": "德国人注重守时和规则，初期适应可能需要时间。大学通常有国际学生服务中心和丰富的社团活动，是结交朋友和融入当地文化的好渠道。德国的博物馆、剧院和音乐会非常丰富，很多对学生提供免费或优惠票价。"
    },
