# Auto detect text files and perform LF normalization
* text=auto

# ─── Web / React ─────────────────────────────────────────────────────────────
*.svg   text eol=lf
*.js    text eol=lf
*.jsx   text eol=lf
*.ts    text eol=lf
*.tsx   text eol=lf
*.html  text eol=lf
*.css   text eol=lf
*.scss  text eol=lf
*.mjs   text eol=lf
*.cjs   text eol=lf

# ─── Python ──────────────────────────────────────────────────────────────────
*.py    text eol=lf

# ─── Lua / OpenResty ─────────────────────────────────────────────────────────
*.lua   text eol=lf

# ─── Docker ──────────────────────────────────────────────────────────────────
Dockerfile      text eol=lf
*.dockerfile    text eol=lf
docker-compose*.yml text eol=lf

# ─── Config / Data ───────────────────────────────────────────────────────────
*.json  text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.toml  text eol=lf
*.ini   text eol=lf
*.conf  text eol=lf
*.md    text eol=lf
*.txt   text eol=lf
*.env   text eol=lf
*.sql   text eol=lf
*.xml   text eol=lf
*.lock  text eol=lf
*.sh    text eol=lf

# ─── Shell scripts (ensure executable line endings) ──────────────────────────
*.sh linguist-language=Shell

# ─── Binary files ────────────────────────────────────────────────────────────
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.eot   binary
*.pyc   binary
*.luac  binary
*.webp  binary
*.avif  binary
*.pdf   binary
